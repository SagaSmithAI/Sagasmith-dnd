{
  "id": "dnd5e-2024",
  "name": "D&D 5e 2024",
  "extends": "dnd5e-2014",
  "status": "framework-placeholder",
  "timeUnits": {
    "turn": {"combat": true},
    "round": {"combat": true},
    "declared_minute": {"timeComponent": "minute"},
    "declared_hour": {"timeComponent": "hour"},
    "declared_day": {"timeComponent": "day"},
    "exploration_turn": {"timeComponent": "exploration"}
  },
  "activityActivationTypes": {
    "action": {"group": "standard"},
    "bonus": {"group": "standard"},
    "reaction": {"group": "standard"},
    "free": {"group": "standard"},
    "minute": {"group": "time", "scalar": true, "period": "declared_minute"},
    "hour": {"group": "time", "scalar": true, "period": "declared_hour"},
    "shortRest": {"group": "rest", "passive": true, "period": "short_rest"},
    "longRest": {"group": "rest", "passive": true, "period": "long_rest"},
    "encounter": {"group": "combat", "passive": true, "period": "encounter_start"},
    "turnStart": {"group": "combat", "passive": true, "period": "turn_start"},
    "turnEnd": {"group": "combat", "passive": true, "period": "turn_end"},
    "special": {"passive": true}
  },
  "activityTypes": {
    "attack": {},
    "check": {},
    "damage": {},
    "effect": {},
    "heal": {},
    "save": {},
    "cast": {},
    "utility": {}
  },
  "limitedUsePeriods": {
    "sr": {"period": "short_rest", "type": "rest"},
    "lr": {"period": "long_rest", "type": "rest"},
    "day": {"period": "declared_day", "type": "time"},
    "recharge": {"period": "recharge", "type": "special"},
    "turnStart": {"period": "turn_start", "type": "combat"},
    "turnEnd": {"period": "turn_end", "type": "combat"},
    "encounter": {"period": "encounter_start", "type": "combat"}
  },
  "activityConsumptionTypes": {
    "activityUses": {},
    "itemUses": {},
    "spellSlots": {},
    "attribute": {},
    "material": {},
    "hitDice": {},
    "turnBudget": {}
  },
  "spellcasting": {
    "defaultSaveDc": "8 + @prof + @spellcasting.mod + @spellcasting.dc_bonus",
    "defaultAttackBonus": "@prof + @spellcasting.mod + @spellcasting.attack_bonus",
    "slotKeys": ["spell1", "spell2", "spell3", "spell4", "spell5", "spell6", "spell7", "spell8", "spell9"],
    "cantripScaling": {"levels": [1, 5, 11, 17], "source": "character_level"},
    "slotScaling": {"source": "cast_spell_level", "minimum": "spell_base_level"},
    "ritual": {"slotCost": false, "requiresPayloadFlag": "ritual"},
    "concentration": {"exclusivePerActor": true, "durationSource": "activity_or_spell_duration"}
  },
  "durationPeriods": {
    "turn_start": {"source": "combat.end_turn", "wallClock": false},
    "turn_end": {"source": "combat.end_turn", "wallClock": false},
    "round_start": {"source": "combat.round_increment", "wallClock": false},
    "encounter_start": {"source": "combat.start", "wallClock": false},
    "encounter_end": {"source": "combat.end", "wallClock": false},
    "short_rest": {"source": "rest.short", "wallClock": false},
    "long_rest": {"source": "rest.long", "wallClock": false},
    "scene_end": {"source": "scene.end", "wallClock": false},
    "declared_minute": {"source": "time.advance", "unitAliases": ["minute", "minutes"], "wallClock": false},
    "declared_hour": {"source": "time.advance", "unitAliases": ["hour", "hours"], "wallClock": false},
    "declared_day": {"source": "time.advance", "unitAliases": ["day", "days"], "wallClock": false},
    "until_turn_start": {"expiresOn": "turn_start", "anchorAware": true},
    "until_turn_end": {"expiresOn": "turn_end", "anchorAware": true}
  },
  "mapRuntime": {
    "documents": ["scene", "token", "region"],
    "token": {
      "visionDerivedFromActorSenses": true,
      "bars": {"bar1": "attributes.hp"},
      "hiddenTokensExcludedFromCombatStart": true,
      "dispositions": ["friendly", "neutral", "hostile", "secret"]
    },
    "movement": {
      "gridDistanceMetadata": "grid_distance",
      "difficultTerrainCostMultiplier": 2,
      "opportunityTrigger": "opportunity_attack"
    },
    "regionBehaviors": {
      "difficult_terrain": {"movementMultiplier": 2},
      "cover": {"degrees": ["half", "three_quarters", "total"]},
      "apply_active_effect": {"createsActorEffect": true, "removeOnExitDefault": true},
      "template": {"origin": "activity"}
    }
  },
  "restRecovery": {
    "short_rest": {
      "recoverActivityUses": ["short_rest"],
      "allowHitDiceSpend": true,
      "recoverSpellSlots": []
    },
    "long_rest": {
      "recoverActivityUses": ["short_rest", "long_rest"],
      "recoverHitPoints": "full",
      "clearTemporaryHitPoints": true,
      "resetDeathSaves": true,
      "recoverHitDice": {"fraction": 0.5, "minimum": 1},
      "recoverSpellSlots": ["spell", "pact"],
      "recoverResources": ["short_rest", "long_rest"]
    }
  },
  "deathSaves": {
    "dc": 10,
    "successesToStabilize": 3,
    "failuresToDie": 3,
    "natural20": {"hp": 1, "reset": true},
    "natural1": {"failures": 2}
  },
