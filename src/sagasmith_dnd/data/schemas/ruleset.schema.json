{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sagasmith.ai/schemas/dnd/ruleset.schema.json",
  "title": "SagaSmith D&D Ruleset",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "name",
    "abilities",
    "skills",
    "damageTypes",
    "actionEconomy",
    "range",
    "cover",
    "resources",
    "effects",
    "timeUnits",
    "activityActivationTypes",
    "activityTypes",
    "limitedUsePeriods",
    "activityConsumptionTypes",
    "activities",
    "conditions",
    "conditionTypes",
    "conditionEffects"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "extends": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "contentPacks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "contentCoverage": {"type": "array", "items": {"type": "object", "additionalProperties": true}},
    "classes": {"type": "object", "additionalProperties": {"$ref": "#/$defs/class"}},
    "subclasses": {"type": "object", "additionalProperties": {"$ref": "#/$defs/subclass"}},
    "classFeatures": {"type": "object", "additionalProperties": {"$ref": "#/$defs/contentEntry"}},
    "spells": {"type": "object", "additionalProperties": {"$ref": "#/$defs/contentEntry"}},
    "monsters": {"type": "object", "additionalProperties": {"$ref": "#/$defs/contentEntry"}},
    "abilities": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/ability"}
    },
    "skills": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/skill"}
    },
    "damageTypes": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/damageType"}
    },
    "actionEconomy": {"$ref": "#/$defs/actionEconomy"},
    "range": {"$ref": "#/$defs/rangeRules"},
    "cover": {"$ref": "#/$defs/coverRules"},
    "resources": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/resource"}
    },
    "effects": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/effectRule"}
    },
    "timeUnits": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/timeUnit"}
    },
    "activityActivationTypes": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/activityActivationType"}
    },
    "activityTypes": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/activityType"}
    },
    "limitedUsePeriods": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/limitedUsePeriod"}
    },
    "activityConsumptionTypes": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/activityConsumptionType"}
    },
    "activities": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/activity"}
    },
    "conditions": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/condition"}
    },
    "conditionTypes": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/conditionType"}
    },
    "conditionEffects": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    }
  },
  "$defs": {
    "contentEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "source_key": {"type": "string"},
        "coverage": {"type": "string"}
      }
    },
    "class": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {"name": {"type": "string", "minLength": 1}, "hit_die": {"type": "string"}}
    },
    "subclass": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "class_key"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "class_key": {"type": "string", "minLength": 1}
      }
    },
    "ability": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "abbreviation": {"type": "string", "minLength": 1},
        "order": {"type": "integer"}
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": true,
      "required": ["ability"],
      "properties": {
        "ability": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1}
      }
    },
    "damageType": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1}
      }
    },
    "actionEconomy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["turnBudget", "attackBudget", "reactionRefresh"],
      "properties": {
        "turnBudget": {"type": "object", "additionalProperties": {"type": "integer"}},
        "attackBudget": {"type": "object", "additionalProperties": true},
        "reactionRefresh": {"type": "string", "minLength": 1},
        "extraActionBudgetKey": {"type": "string", "minLength": 1}
      }
    },
    "rangeRules": {
      "type": "object",
      "additionalProperties": true,
      "required": ["units", "modes"],
      "properties": {
        "units": {"type": "string", "minLength": 1},
        "modes": {"type": "object", "additionalProperties": true},
        "longRangeDisadvantage": {"type": "boolean"},
        "beyondLongRange": {"type": "string", "minLength": 1},
        "rangedAttackWithinHostileReach": {"type": "string", "minLength": 1}
      }
    },
    "coverRules": {
      "type": "object",
      "additionalProperties": true,
      "required": ["degrees"],
      "properties": {
        "degrees": {"type": "object", "additionalProperties": {"type": "object", "additionalProperties": true}}
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "recovery": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "maxFormula": {"type": "string"},
        "scope": {"type": "string"}
      }
    },
    "effectRule": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "period": {"type": "string"},
        "exclusivePerActor": {"type": "boolean"}
      }
    },
    "timeUnit": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "combat": {"type": "boolean"},
        "timeComponent": {"type": "string"}
      }
    },
    "activityActivationType": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "group": {"type": "string"},
        "scalar": {"type": "boolean"},
        "passive": {"type": "boolean"},
        "period": {"type": "string"}
      }
    },
    "activityType": {
      "type": "object",
      "additionalProperties": true
    },
    "limitedUsePeriod": {
      "type": "object",
      "additionalProperties": true,
      "required": ["period", "type"],
      "properties": {
        "period": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1}
      }
    },
    "activityConsumptionType": {
      "type": "object",
      "additionalProperties": true
    },
    "activity": {
      "type": "object",
      "additionalProperties": true,
      "required": ["activation", "type"],
      "properties": {
        "activation": {"type": "string", "minLength": 1},
        "type": {"type": "string", "minLength": 1},
        "requires_feature": {"type": "string"},
        "trigger": {"type": "string"},
        "uses": {"$ref": "#/$defs/uses"},
        "grant": {
          "type": "object",
          "additionalProperties": {"type": ["integer", "number", "string", "boolean", "array", "object", "null"]}
        },
        "healing": {"type": "string"},
        "effect": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "uses": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "resource": {"type": "string", "minLength": 1},
        "cost": {"type": "integer", "minimum": 0},
        "recovery": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "condition": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tags": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "conditionType": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "statuses": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "riders": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
