{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sagasmith.ai/schemas/dnd5e/rule-pack-v1.schema.json",
  "title": "SagaSmith D&D Rule Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "system_id", "editions"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"},
    "title": {"type": "string", "maxLength": 300},
    "namespace": {"type": "string", "maxLength": 200},
    "system_id": {"const": "dnd5e"},
    "editions": {"type": "array", "items": {"enum": ["2014", "2024"]}, "uniqueItems": true},
    "dependencies": {
      "type": "array",
      "items": {
        "oneOf": [
          {"type": "string"},
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {"id": {"type": "string"}, "version": {"type": "string"}}
          }
        ]
      }
    },
    "conflicts": {"type": "array", "items": {"type": ["string", "object"]}},
    "capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "provenance": {"type": "object"},
    "tests": {"type": "array", "items": {"type": "object"}}
  }
}
